{
  "name": "@xyzsaas/utils",
  "version": "0.0.6",
  "description": "My JavaScript utils library",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test": "vitest run",
    "lint": "eslint src --ext .js,.ts",
    "npmjs": "npm publish --access public --registry=https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/szuprefix/xyz-utils.git"
  },
  "keywords": [
    "utils",
    "xyz"
  ],
  "author": "szuprefix@126.com",
  "license": "ISC",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./*": "./dist/*"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-terser": "^0.4.0",
    "@rollup/plugin-typescript": "^11.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "rollup": "^4.0.0",
    "rollup-plugin-dts": "^6.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "lodash": "^4.17.23",
    "tslib": "^2.8.1"
  }
}
